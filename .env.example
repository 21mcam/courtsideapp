# Backend listen port. Railway injects PORT automatically in prod.
PORT=3000

# Node env. "development" enables verbose error responses; "production" hides them.
NODE_ENV=development

# Postgres connection string for the runtime role (app_runtime, NOT a superuser).
#
# Use Supabase's connection pooler (Supavisor), NOT the direct connection
# host. The direct host (db.{ref}.supabase.co) requires Supabase's paid
# IPv4 add-on; the pooler is on free tier.
#
# Format: USER.PROJECT_REF in the user portion, pooler host, port 6543
# (transaction mode — works fine with our `set_config(..., true)`
# pattern since the GUC is transaction-local).
#
# Find the template under: Supabase dashboard → Project Settings →
# Database → Connection pooling. Replace the default `postgres` user
# with `app_runtime`.
DATABASE_URL=postgresql://app_runtime.YOUR-PROJECT-REF:CHANGE_ME@aws-0-YOUR-REGION.pooler.supabase.com:6543/postgres

# Apex hostname the app is deployed under. Subdomains resolve as
# {subdomain}.{APP_HOSTNAME} and middleware splits the tenant off.
# In dev, leave as "localhost" and use {tenant}.localhost (works in modern
# browsers without /etc/hosts edits) or ?tenant=foo as a fallback.
APP_HOSTNAME=localhost

# JWT signing secret. Long random string. NEVER commit a real value.
JWT_SECRET=CHANGE_ME

# Privileged DB connection — used ONLY by the auth tests in
# tests/auth.test.js to create/destroy throwaway test tenants. Same
# host/port as DATABASE_URL but with the postgres superuser instead
# of app_runtime. Leave unset if you don't need to run those tests
# locally; they skip cleanly. CI sets this automatically against the
# disposable Postgres service container.
#
# Example: postgresql://postgres.YOUR-PROJECT-REF:POSTGRES-PASSWORD@aws-X-YOUR-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL_PRIVILEGED=

# Stripe (Phase 3+). Test keys for dev.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# Resend (Phase 3+).
RESEND_API_KEY=

